{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(python -m pytest*)",
      "Bash(py -m pytest*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git push --force*)",
      "Read(**/.env*)"
    ]
  }
}
